---
import Base from "../../layouts/Base.astro";
import { pollutionHeadline } from "../../data/pollution";

const dashboards = [
  {
    href: "/dashboards/pollution/",
    kicker: "Pollution cycle",
    title: "Air, water & food contamination",
    body: "The most pervasive crisis on the index: PM₂.₅ by region and source, drinking-water access, food-chain contamination, and how pollutants cycle through every medium into the body.",
    tag: "Featured",
    views: "5 views",
  },
  {
    href: "/dashboards/climate/",
    kicker: "Climate & global warming",
    title: "Warming paths, emissions & sea level",
    body: "The forcing function beneath the index: warming trajectories to 2100, CO₂ emissions by region, sea-level rise, and the tipping elements within reach near 1.5°C.",
    tag: "Climate",
    views: "3 views",
  },
  {
    href: "/dashboards/heat/",
    kicker: "Heat & devices",
    title: "Heat, WBGT & regional exposure",
    body: "Late-century peaks in air, feels-like and work-safety (WBGT) temperature; lived mean temperature; device thermal limits; and the share of each region in unsafe conditions.",
    tag: "Climate",
    views: "3 explorers",
  },
  {
    href: "/dashboards/inequality/",
    kicker: "Inequality & poverty",
    title: "Wealth, income & the equity gap",
    body: "Global wealth and income concentration, the stalled decline of extreme poverty, and the gap between who causes climate harm and who carries it.",
    tag: "Social",
    views: "4 views",
  },
  {
    href: "/dashboards/demographics/",
    kicker: "Demographic shifts",
    title: "Africa's rise, Europe's decline",
    body: "The great divergence: Sub-Saharan Africa's tripling versus Europe's and East Asia's contraction, median age, and the old-age dependency squeeze.",
    tag: "Social",
    views: "3 views",
  },
  {
    href: "/dashboards/cybercrime/",
    kicker: "Cybercrime & digital",
    title: "The friction tax on the digital layer",
    body: "The trajectory of cybercrime cost, attack types, most-targeted sectors, and the digital divide that shapes who is exposed and who is left offline.",
    tag: "Digital",
    views: "4 views",
  },
  {
    href: "/dashboards/cascades/",
    kicker: "Secondary effects",
    title: "Cascades: battery waste, feels-like heat",
    body: "The second-order effects that often outweigh the first: battery and e-waste growth, feels-like city temperatures, and the compound heat-pollution stress facing most of humanity.",
    tag: "Cascade",
    views: "3 views",
  },
];
---

<Base
  title="Dashboards"
  description="Interactive dashboards across the century's pressing issues — pollution, heat, inequality and cybercrime — with the data behind each."
>
  <header class="page-head">
    <div class="container page-head-inner">
      <div class="breadcrumb"><a href="/">Home</a> / Dashboards</div>
      <span class="kicker">Interactive data</span>
      <h1>Dashboards across the century's pressing issues</h1>
      <p class="lede">
        One framework, many pressures. Each dashboard isolates a structural problem — pollution, heat,
        inequality, cybercrime — and lets you explore the data behind it. They are not separate stories:
        every one couples to the others through the same systems.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="grid g-2">
        {dashboards.map((d) => (
          <a href={d.href} class="card card--link">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;">
              <span class="card-kicker">{d.kicker}</span>
              <span class="tag">{d.tag}</span>
            </div>
            <h3>{d.title}</h3>
            <p>{d.body}</p>
            <span class="card-foot">Open dashboard · {d.views} <span class="arr">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <h2>The largest burden: pollution</h2>
        <span class="meta">Why it leads the dashboards</span>
      </div>
      <div class="grid g-4">
        {pollutionHeadline.map((h) => (
          <div class="stat sig">
            <div class="num">{h.num}</div>
            <div class="label">{h.label}</div>
            <div class="src">{h.src}</div>
          </div>
        ))}
      </div>
      <div class="callout" style="margin-top:26px;">
        <div class="co-label">A coupled system</div>
        <p class="mb-0">
          Pollution kills more people each year than war, hunger and most disease categories — and it
          moves. Air settles into water, water irrigates soil, soil feeds crops, crops reach the body.
          The <a href="/dashboards/pollution/">pollution dashboard</a> and the
          <a href="/reports/pollution-cycle/"> pollution-cycle report</a> trace that loop end to end.
        </p>
      </div>
    </div>
  </section>
</Base>
