---
import Base from "../../layouts/Base.astro";
import { mitigations, universalRule, mitigationCeiling, type Lever } from "../../data/mitigation";
import { problems } from "../../data/hcpi";

const levers: Lever[] = ["Path", "Stock", "Medium", "D", "Allocation"];
const scoreFor = (id: string) => problems.find((p) => p.id === id);
const orderedMitigations = [...mitigations].sort(
  (a, b) => (scoreFor(b.problemId)?.hcpi ?? b.hcpi) - (scoreFor(a.problemId)?.hcpi ?? a.hcpi)
);
---

<Base
  title="Mitigation Framework"
  description="Five universal levers — Path, Stock, Medium, D and Allocation — applied to each Tier I systemic core, with what is mitigable and what is beyond control."
>
  <header class="page-head">
    <div class="container page-head-inner">
      <div class="breadcrumb"><a href="/">Home</a> / Mitigation</div>
      <span class="kicker">What remains mitigable</span>
      <h1>Five levers, applied to the systemic cores</h1>
      <p class="lede">
        Every problem in the index can be acted on through the same five levers. The honest ceiling:
        committed warming, demographic weight in hot zones and default inequality are beyond control.
        Mitigation is navigation — choosing the buffer, not erasing the regime.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>The universal rule</h2>
        <span class="meta">Applies to all 12</span>
      </div>
      <div class="mit-block" style="margin-bottom:0;">
        {universalRule.map((r) => (
          <div class="lever-row">
            <div class="lv-name">{r.lever}</div>
            <div class="lv-body">{r.meaning}</div>
          </div>
        ))}
      </div>
      <div class="grid g-2" style="margin-top:24px;">
        <div class="callout">
          <div class="co-label">Timing</div>
          <p class="mb-0">{mitigationCeiling.timing}</p>
        </div>
        <div class="callout navy">
          <div class="co-label">Honest ceiling</div>
          <p class="mb-0">{mitigationCeiling.beyondControl}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <h2>Tier I — systemic cores</h2>
        <span class="meta">Lever-by-lever</span>
      </div>

      {orderedMitigations.map((m) => {
        const p = scoreFor(m.problemId);
        const hcpi = p ? p.hcpi : m.hcpi;
        const tier = p ? p.tier : m.tier;
        return (
        <div class="mit-block">
          <div class="mb-head">
            <h3>{m.problem}</h3>
            <span class="tag t-crit">HCPI {hcpi.toFixed(1)} · Tier {tier}</span>
          </div>
          <p class="mb-statement">{m.statement}</p>
          <div class="mb-levers">
            {levers.map((l) => (
              <div class="lever-row">
                <div class="lv-name">{l}</div>
                <div class="lv-body">{m.levers[l]}</div>
              </div>
            ))}
          </div>
          <div class="mb-foot">
            <div class="wrong"><b>Wrong metric:</b> {m.wrong}</div>
            <div class="right"><b>Right metric:</b> {m.right}</div>
          </div>
        </div>
        );
      })}
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <h2>The principle underneath</h2>
      <p class="lede">
        Across every lever the same logic holds: <strong>install absorptive capacity before the curves
        synchronize.</strong> Finance, grid, cooling and institutions that compound into stock are the
        difference between a buffered city and one inside the chronic-risk envelope.
      </p>
      <p>
        Reacting inside the 2040–2060 danger window means buying the same capacity at peak prices — the
        complexity tax. Front-loading the 2020s–2030s is the only lever that bends late-century
        exposure rather than merely responding to it.
      </p>
      <div class="hero-actions" style="margin-top:8px;">
        <a href="/crisis-index/" class="btn btn--ghost">Back to the Crisis Index <span class="arr">→</span></a>
        <a href="/reports/" class="btn btn--ghost">Read the reports</a>
      </div>
    </div>
  </section>
</Base>
