---
import Report from "../../layouts/Report.astro";
const toc = [
  { id: "medium", label: "The medium, not the maximum" },
  { id: "metrics", label: "Three metrics" },
  { id: "cognition", label: "Cognition & learning" },
  { id: "devices", label: "Heat and devices" },
  { id: "wet-bulb", label: "The wet-bulb tail" },
